# Aurora Weather - Environment Variables
#
# Open-Meteo is a free, open-source weather API that requires NO API key.
# These URLs are provided as overridable environment variables so you can
# point to a self-hosted Open-Meteo instance or a regional mirror if needed.
# If left unset, the public Open-Meteo endpoints below are used by default.

NEXT_PUBLIC_OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
NEXT_PUBLIC_OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality
NEXT_PUBLIC_OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
